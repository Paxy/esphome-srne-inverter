wifi_ssid: "your-ssid"
wifi_password: "your-password"

# Required by atoms3r-example.yaml (omit if you only use esp32-example.yaml / esp32s3-example.yaml)
# Generate api_encryption_key: python3 -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
# Generate ota_password:       python3 -c "import secrets;print(secrets.token_hex(16))"
api_encryption_key: "base64-encoded-32-byte-key-here"
ota_password: "32-hex-char-password-here"
fallback_ap_password: "min-8-chars"
